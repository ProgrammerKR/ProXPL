use std.ui;

App MyLibraryApp {
    State count = 0;

    Action increment {
        count = count + 1;
    }

    Window MainWindow {
        Container(className: "hero") {
            Text(value: "Welcome to ProXPL UI");
            Button(onClick: increment) {
                Text(value: "Click Me");
            }
            Text(value: count);
        }
    }
}
