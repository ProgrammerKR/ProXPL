# ProX Project Configuration

project {
    name: "ProXplore"
    version: "1.0.0"
    author: "Kanishk Raj"
    license: "MIT"
}

compiler {
    optimize: true
    debug: false
    target: "native"
}

paths {
    src: "./src"
    build: "./build"
}

dependencies {
    http: "1.2.0"
    json: "1.1.0"
}

runtime {
    threads: 8
    memory_limit: "1GB"
}
