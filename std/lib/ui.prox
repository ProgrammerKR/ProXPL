// ===================================================
//  SECTION 6: SHADOW SYSTEM
// ===================================================

const SHADOW_NONE     = "box-shadow: none";
const SHADOW_SM       = "box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05)";
const SHADOW_MD       = "box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06)";
