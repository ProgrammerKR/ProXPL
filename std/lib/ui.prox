const SHADOW_XL       = "box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04)";
const SHADOW_2XL      = "box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25)";
const SHADOW_INNER    = "box-shadow: inset 0 2px 4px 0 rgba(0, 0, 0, 0.06)";
const SHADOW_SOFT     = "box-shadow: 0 4px 20px 0 rgba(0, 0, 0, 0.05)";
const SHADOW_GOLD     = "box-shadow: 0 10px 30px -5px rgba(184, 134, 11, 0.3)";
const SHADOW_BLUE     = "box-shadow: 0 10px 30px -5px rgba(59, 130, 246, 0.4)";
const SHADOW_PURPLE   = "box-shadow: 0 10px 30px -5px rgba(139, 92, 246, 0.4)";
const SHADOW_GREEN    = "box-shadow: 0 10px 30px -5px rgba(16, 185, 129, 0.4)";

// Neumorphism Shadows
const SHADOW_NEUMORPH_OUT = "box-shadow: 9px 9px 16px rgb(163,177,198,0.6), -9px -9px 16px rgba(255,255,255, 0.5)";
const SHADOW_NEUMORPH_IN  = "box-shadow: inset 9px 9px 16px rgb(163,177,198,0.6), inset -9px -9px 16px rgba(255,255,255, 0.5)";

// ===================================================
//  SECTION 7: LAYOUT & FLEX/GRID
// ===================================================

const LAYOUT_CENTER  = "display: flex; justify-content: center; align-items: center";
const LAYOUT_COL     = "display: flex; flex-direction: column";
const LAYOUT_ROW     = "display: flex; flex-direction: row";
const LAYOUT_GRID    = "display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem";
const LAYOUT_WRAP    = "display: flex; flex-wrap: wrap";
const LAYOUT_STACK   = "display: flex; flex-direction: column; gap: 1rem";

// Flex Helpers
const FLEX_BETWEEN   = "display: flex; justify-content: space-between; align-items: center";
const FLEX_START     = "display: flex; justify-content: flex-start; align-items: center";
const FLEX_END       = "display: flex; justify-content: flex-end; align-items: center";
