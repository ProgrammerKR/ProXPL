const MODAL_DARK     = "background: #1e293b; border-radius: 1.5rem; padding: 2.5rem; max-width: 32rem; width: 100%; border: 1px solid #334155; color: #f1f5f9";
const MODAL_HEADER   = FLEX_BETWEEN + "; margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1px solid " + COLOR_BORDER;
const MODAL_FOOTER   = FLEX_END + "; gap: 0.75rem; margin-top: 2rem; padding-top: 1rem; border-top: 1px solid " + COLOR_BORDER;

// ===================================================
//  SECTION 15: TABLES
// ===================================================

const TABLE_BASE    = "width: 100%; border-collapse: collapse; background: " + COLOR_WHITE + "; border-radius: 1rem; overflow: hidden; box-shadow: " + SHADOW_MD;
const TABLE_HEAD    = "background: " + COLOR_SURFACE + "; text-align: left; color: " + COLOR_MUTED + "; font-weight: 700; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.1em; padding: 1rem 1.25rem; border-bottom: 1px solid " + COLOR_BORDER;
const TABLE_ROW     = "transition: background 0.15s ease; border-bottom: 1px solid " + COLOR_BORDER;
const TABLE_ROW_ACT = "background: rgba(59,130,246,0.05)";
const TABLE_CELL    = "padding: 1rem 1.25rem; color: " + COLOR_DARK + "; font-size: 0.9rem";

// ===================================================
//  SECTION 16: DASHBOARD COMPONENTS
// ===================================================

const STAT_CARD   = CARD_BASE + "; display: flex; flex-direction: column; min-width: 220px";
const STAT_VALUE  = "font-size: 2rem; font-weight: 900; color: " + COLOR_DARK + "; margin: 0.5rem 0; line-height: 1";
const STAT_LABEL  = "font-size: 0.75rem; text-transform: uppercase; font-weight: 700; color: " + COLOR_MUTED + "; letter-spacing: 0.1em";
const STAT_CHANGE = "font-size: 0.875rem; font-weight: 600";
const STAT_UP     = STAT_CHANGE + "; color: " + COLOR_SUCCESS;
const STAT_DOWN   = STAT_CHANGE + "; color: " + COLOR_DANGER;

// Progress Bars
const PROGRESS_WRAP    = "width: 100%; height: 0.5rem; background: " + COLOR_LIGHT + "; border-radius: 9999px; overflow: hidden";
const PROGRESS_FILL    = "height: 100%; background: " + GRADIENT_PRIMARY + "; border-radius: 9999px; transition: width 0.5s ease";
const PROGRESS_SUCCESS = "height: 100%; background: " + GRADIENT_SUCCESS + "; border-radius: 9999px";
const PROGRESS_DANGER  = "height: 100%; background: linear-gradient(90deg, #ef4444, #dc2626); border-radius: 9999px";
const PROGRESS_ORANGE  = "height: 100%; background: linear-gradient(90deg, #f97316, #ea580c); border-radius: 9999px";

// ===================================================
//  SECTION 17: MEDIA & GRAPHICS
// ===================================================

const IMAGE_CIRCLE   = "border-radius: 50%; border: 4px solid " + COLOR_WHITE + "; box-shadow: " + SHADOW_XL + "; aspect-ratio: 1; object-fit: cover";
const IMAGE_CARD     = "border-radius: 0.75rem; object-fit: cover; width: 100%";
const VIDEO_PLAYER   = "border-radius: 1.5rem; box-shadow: " + SHADOW_2XL + "; border: 8px solid #111827; overflow: hidden; width: 100%";
const CANVAS_FULL    = "width: 100%; height: 100%; background: #000; cursor: crosshair";
const AVATAR_SM      = "width: 2rem; height: 2rem; border-radius: 50%; object-fit: cover";
const AVATAR_MD      = "width: 3rem; height: 3rem; border-radius: 50%; object-fit: cover";
const AVATAR_LG      = "width: 5rem; height: 5rem; border-radius: 50%; object-fit: cover; border: 4px solid " + COLOR_WHITE + "; " + SHADOW_LG;

// ===================================================
//  SECTION 18: ANIMATIONS
// ===================================================

const ANIM_FADE_IN   = "@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }; animation: fadeIn 0.5s ease-out";
const ANIM_FADE_OUT  = "@keyframes fadeOut { from { opacity: 1; } to { opacity: 0; } }; animation: fadeOut 0.5s ease-out";
const ANIM_SLIDE_UP  = "@keyframes slideUp { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }; animation: slideUp 0.5s ease-out";
const ANIM_SLIDE_DOWN = "@keyframes slideDown { from { transform: translateY(-20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }; animation: slideDown 0.4s ease-out";
const ANIM_SLIDE_LEFT = "@keyframes slideLeft { from { transform: translateX(30px); opacity: 0; } to { transform: translateX(0); opacity: 1; } }; animation: slideLeft 0.4s ease-out";
const ANIM_BOUNCE    = "@keyframes bounce { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }; animation: bounce 1s infinite";
const ANIM_SPIN      = "@keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }; animation: spin 1s linear infinite";
const ANIM_PULSE     = "@keyframes pulse { 0% { opacity: 1; transform: scale(1); } 50% { opacity: 0.8; transform: scale(1.03); } 100% { opacity: 1; transform: scale(1); } }; animation: pulse 2s infinite";
const ANIM_SHAKE     = "@keyframes shake { 0%, 100% { transform: translateX(0); } 25% { transform: translateX(-6px); } 75% { transform: translateX(6px); } }; animation: shake 0.5s ease-out";
const ANIM_FLIP      = "@keyframes flip { from { transform: rotateY(0deg); } to { transform: rotateY(360deg); } }; animation: flip 1s ease-in-out";
const ANIM_ZOOM_IN   = "@keyframes zoomIn { from { transform: scale(0.8); opacity: 0; } to { transform: scale(1); opacity: 1; } }; animation: zoomIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1)";
const ANIM_WAVE      = "@keyframes wave { 0%, 100% { transform: rotate(0deg); } 25% { transform: rotate(20deg); } 75% { transform: rotate(-20deg); } }; animation: wave 1.5s ease infinite";
const ANIM_REVEAL    = "@keyframes reveal { from { clip-path: inset(0 100% 0 0); } to { clip-path: inset(0 0% 0 0); } }; animation: reveal 0.6s ease-out";
const ANIM_SKELETON  = "background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%); background-size: 200% 100%; @keyframes loadingShimmer { from { background-position: 200% 0; } to { background-position: -200% 0; } }; animation: loadingShimmer 1.5s infinite";

// Transition Utilities
const TRANSITION_FAST   = "transition: all 0.15s ease-in-out";
const TRANSITION_NORMAL = "transition: all 0.3s ease-in-out";
const TRANSITION_SLOW   = "transition: all 0.5s ease-in-out";
const TRANSITION_SPRING = "transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1)";

// Extra Components
const ACCORDION_ITEM  = "border-bottom: 1px solid " + COLOR_BORDER + "; overflow: hidden";
const ACCORDION_BTN   = "width: 100%; padding: 1rem; text-align: left; background: none; border: none; font-weight: 600; cursor: pointer";
const TOOLTIP_WRAP    = "position: relative; display: inline-block";
const TOOLTIP_BOX     = "position: absolute; bottom: 100%; left: 50%; transform: translateX(-50%); padding: 0.5rem; background: #000; color: #fff; font-size: 0.75rem; border-radius: 0.25rem; visibility: hidden; opacity: 0; transition: opacity 0.2s";
const BREADCRUMB_ITEM = "display: inline-flex; align-items: center; color: " + COLOR_MUTED + "; font-size: 0.875rem";
const BREADCRUMB_SEP  = "margin: 0 0.5rem; color: " + COLOR_BORDER;

// ===================================================
//  SECTION 19: FILTERS & EFFECTS
// ===================================================

const BLUR_SM        = "filter: blur(4px)";
const BLUR_MD        = "filter: blur(8px)";
const BLUR_LG        = "filter: blur(16px)";
const SATURATE_HIGH  = "filter: saturate(1.5)";
const GRAYSCALE      = "filter: grayscale(1)";
const BRIGHTNESS_UP  = "filter: brightness(1.15)";
const BRIGHTNESS_DOWN = "filter: brightness(0.85)";
const SEPIA          = "filter: sepia(0.6)";

// Backdrop Filters
const BACKDROP_BLUR_SM  = "backdrop-filter: blur(4px)";
const BACKDROP_BLUR_MD  = "backdrop-filter: blur(12px)";
const BACKDROP_BLUR_LG  = "backdrop-filter: blur(20px)";
const BACKDROP_SATURATE = "backdrop-filter: saturate(180%)";

// ===================================================
