const ROUNDED        = "border-radius: 0.25rem";
const ROUNDED_MD     = "border-radius: 0.375rem";
const ROUNDED_LG     = "border-radius: 0.5rem";
const ROUNDED_XL     = "border-radius: 0.75rem";
