// Button Color Variants
const BTN_PRIMARY   = "background: " + GRADIENT_PRIMARY + "; color: #ffffff; box-shadow: 0 4px 15px rgba(59,130,246,0.4)";
const BTN_SECONDARY = "background: " + GRADIENT_SUCCESS + "; color: #ffffff; box-shadow: 0 4px 15px rgba(16,185,129,0.4)";
