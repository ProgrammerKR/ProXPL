//  SECTION 14: MODALS
// ===================================================

const MODAL_OVERLAY  = "position: fixed; inset: 0; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); z-index: 9999; display: flex; align-items: center; justify-content: center; padding: 1rem";
