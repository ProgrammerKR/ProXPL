const FLEX_SHRINK    = "flex: 0 0 auto";
const FLEX_1         = "flex: 1";

// Grid Presets
const GRID_2_COL     = "display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem";
const GRID_3_COL     = "display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem";
const GRID_4_COL     = "display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem";

// Layout Presets
const CENTER_FULL    = "display: flex; justify-content: center; align-items: center; min-height: 100vh; background: " + COLOR_LIGHT;
const GRID_DASHBOARD = "display: grid; grid-template-columns: 250px 1fr; min-height: 100vh";

// Bento Grid Utilities
const BENTO_GRID     = "display: grid; grid-template-columns: repeat(4, 1fr); grid-auto-rows: minmax(150px, auto); gap: 1.5rem";
