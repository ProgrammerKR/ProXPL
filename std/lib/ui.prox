const BTN_BASE      = "display: inline-flex; align-items: center; justify-content: center; padding: 0.5rem 1rem; border-radius: 0.5rem; font-weight: 500; font-family: " + FONT_SANS + "; transition: all 0.2s ease; cursor: pointer; border: none; outline: none; text-decoration: none";
