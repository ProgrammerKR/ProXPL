// Light Theme
const THEME_LIGHT     = "background-color: " + COLOR_WHITE + "; color: " + COLOR_DARK + "; font-family: " + FONT_SANS;

// Dark Theme
const THEME_DARK      = "background-color: #0f172a; color: #f1f5f9; font-family: " + FONT_SANS;
const DARK_SURFACE    = "background-color: #1e293b";
const DARK_ELEVATED   = "background-color: #334155";
const DARK_BORDER     = "border-color: #475569";
const DARK_TEXT       = "color: #f1f5f9";
const DARK_TEXT_MUTED = "color: #94a3b8";

// ProXPL Official Themes
const PROX_THEME_OCEAN  = "background: linear-gradient(to bottom, #ebf8ff, #ffffff); font-family: " + FONT_SANS;
const PROX_THEME_CYBER  = "background: #000000; color: #00ff00; font-family: " + FONT_MONO;
const PROX_THEME_MIDNIGHT = "background: " + GRADIENT_NIGHT + "; font-family: " + FONT_SANS + "; color: #e2e8f0; min-height: 100vh";
const PROX_THEME_AURORA = "background: linear-gradient(135deg, #0f0c29 0%, #1a1a4e 40%, #24243e 100%); font-family: " + FONT_SANS + "; color: #f0f4ff; min-height: 100vh";
const PROX_THEME_DAWN   = "background: linear-gradient(to bottom right, #ffecd2, #fcb69f, #ffd1ff); font-family: " + FONT_SANS + "; min-height: 100vh";
const PROX_THEME_FOREST = "background: linear-gradient(135deg, #134e4a, #0f766e); font-family: " + FONT_SANS + "; color: #f0fdf4; min-height: 100vh";

// ===================================================
//  SECTION 23: HOW TO USE THE PROX UI LIBRARY
// ===================================================

/*
  HOW TO USE THE PROX UI LIBRARY:
  ─────────────────────────────────────────────────
  1. Import at the top:        `use UI;`
  2. Define App block:         `App MyApp { ... }`
  3. Declare reactive state:   `State count = 0;`
  4. Define actions:           `Action doSomething { ... }`
  5. Use Window/Main for layout
  
  BUILD WEB COMMANDS (prm):
  ─────────────────────────────────────────────────
  prm build web                   Build UI to dist/ folder
  prm build web --output myapp    Build to custom folder
  proxpl build web src/main.prox  Build specific file
  
  COMMONLY USED TOKENS:
  ─────────────────────────────────────────────────
  Layout:    LAYOUT_ROW, LAYOUT_COL, LAYOUT_GRID, FLEX_BETWEEN
  Buttons:   BTN_BASE + BTN_PRIMARY / BTN_SECONDARY / BTN_DANGER
  Cards:     CARD_BASE, GLASS_CARD, NEU_BASE
  Text:      TEXT_XL, FONT_BOLD, COLOR_PRIMARY
  Themes:    PROX_THEME_MIDNIGHT, PROX_THEME_AURORA
  Anim:      ANIM_FADE_IN, ANIM_SLIDE_UP, ANIM_ZOOM_IN
  
  EXAMPLE (Dashboard):
  ─────────────────────────────────────────────────
  App Dashboard {
      State user = "ProgrammerKR";
      State count = 42;
      
      Main(style: PROX_THEME_MIDNIGHT) {
          Nav(style: NAV_DARK) {
              Text(style: TEXT_XL + "; " + FONT_BOLD) { "Dashboard" }
          }
          
          Section(style: "padding: 3rem; " + LAYOUT_GRID) {
              Container(style: GLASS_CARD + "; " + ANIM_ZOOM_IN) {
                  Text(style: STAT_LABEL) { "Active Users" }
                  Text(style: STAT_VALUE) { count }
                  Text(style: BADGE_SUCCESS) { "LIVE" }
              }
          }
      }
  }
*/
